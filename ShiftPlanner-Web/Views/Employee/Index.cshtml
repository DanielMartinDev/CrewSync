<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Weekly Hours</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.EmployeeID</td>
                <td>@employee.Name</td>
                <td>@employee.WeeklyHours</td>
                <td>
                    <a asp-action="Details" asp-route-id="@employee.EmployeeID"> 
                        View Details
                    </a>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@employee.EmployeeID">
                        Edit Employee
                    </a>
                </td>
                <td>
                    <a asp-action="Delete"
                       asp-route-id="@employee.EmployeeID"
                       class="btn btn-danger">
                        Delete
                    </a>
                </td>
            </tr>
        }

        <a asp-action="Create" class="btn btn-primary mb-3">
            Add Employee
        </a>
    </tbody>
</table>