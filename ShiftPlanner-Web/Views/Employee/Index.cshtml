@model List<Shift_Planner_Web.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h1 class="fw-bold mb-1">
            Employees
        </h1>

        <p class="text-muted mb-0">
            Manage your workforce, contracts and scheduling.
        </p>

    </div>

    <a asp-action="Create"
       class="btn btn-primary">

        Add Employee

    </a>

</div>

<div class="card">

    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">

                    <tr>

                        <th>Name</th>
                        <th>Role</th>
                        <th>Contract</th>
                        <th>Scheduled</th>
                        <th>Remaining</th>
                        <th>Utilisation</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var employee in Model)
                    {
                        string status;
                        string badgeClass;

                        if (employee.ScheduledHours == 0)
                        {
                            status = "No Shifts";
                            badgeClass = "bg-secondary";
                        }
                        else if (employee.ScheduledHours > employee.WeeklyHours)
                        {
                            status = "Over Contract";
                            badgeClass = "bg-danger";
                        }
                        else if (employee.Utilisation >= 90)
                        {
                            status = "Fully Scheduled";
                            badgeClass = "bg-success";
                        }
                        else
                        {
                            status = "Under Hours";
                            badgeClass = "bg-warning text-dark";
                        }

                        <tr>

                            <td>

                                <div class="fw-semibold">
                                    @employee.Name
                                </div>

                                <small class="text-muted">
                                    ID #@employee.EmployeeID
                                </small>

                            </td>

                            <td>
                                @employee.Role.ToString().Replace("_", " ")
                            </td>

                            <td>
                                @employee.WeeklyHours hrs
                            </td>

                            <td>
                                @employee.ScheduledHours hrs
                            </td>

                            <td>
                                @employee.RemainingHours hrs
                            </td>

                            <td>

                                <div class="fw-semibold">
                                    @employee.Utilisation%
                                </div>

                            </td>

                            <td>

                                <span class="badge @badgeClass">

                                    @status

                                </span>

                            </td>

                            <td>

                                <div class="d-flex justify-content-end gap-2">

                                    <a asp-action="Details"
                                       asp-route-id="@employee.EmployeeID"
                                       class="btn btn-outline-primary btn-sm">

                                        View

                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@employee.EmployeeID"
                                       class="btn btn-outline-secondary btn-sm">

                                        Edit

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@employee.EmployeeID"
                                       class="btn btn-outline-danger btn-sm">

                                        Delete

                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>