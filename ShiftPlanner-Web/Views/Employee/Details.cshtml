@model Shift_Planner_Web.Models.Employee

@{
    ViewData["Title"] = "Employee Profile";

    string status;
    string badgeClass;

    if (Model.ScheduledHours == 0)
    {
        status = "No Shifts";
        badgeClass = "bg-secondary";
    }
    else if (Model.ScheduledHours > Model.WeeklyHours)
    {
        status = "Over Contract";
        badgeClass = "bg-danger";
    }
    else if (Model.Utilisation >= 90)
    {
        status = "Fully Scheduled";
        badgeClass = "bg-success";
    }
    else
    {
        status = "Under Hours";
        badgeClass = "bg-warning text-dark";
    }
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center">

            <div>

                <h1 class="fw-bold mb-1">
                    @Model.Name
                </h1>

                <div class="text-muted">

                    @Model.Role.ToString().Replace("_", " ")
                    • Started
                    @Model.StartDate.ToString("dd MMM yyyy")

                </div>

            </div>

            <span class="badge @badgeClass fs-6">
                @status
            </span>

        </div>

    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">

        <div class="card shadow-sm border-0">

            <div class="card-body text-center">

                <div class="text-muted">
                    Contract Hours
                </div>

                <h2>
                    @Model.WeeklyHours
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card shadow-sm border-0">

            <div class="card-body text-center">

                <div class="text-muted">
                    Scheduled
                </div>

                <h2>
                    @Model.ScheduledHours
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card shadow-sm border-0">

            <div class="card-body text-center">

                <div class="text-muted">
                    Remaining
                </div>

                <h2>
                    @Model.RemainingHours
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card shadow-sm border-0">

            <div class="card-body text-center">

                <div class="text-muted">
                    Utilisation
                </div>

                <h2>
                    @Model.Utilisation%
                </h2>

            </div>

        </div>

    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white">

        <h5 class="mb-0">
            Workload
        </h5>

    </div>

    <div class="card-body">

        <div class="progress"
             style="height: 30px;">

            <div class="progress-bar
                @(Model.Utilisation >= 100 ? "bg-danger" :
                   Model.Utilisation >= 90 ? "bg-success" :
                   "bg-warning")"
                 style="width:@Model.Utilisation%">

                @Model.Utilisation%

            </div>

        </div>

    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">

        <h5 class="mb-0">
            Upcoming Shifts
        </h5>

        <span class="badge bg-primary">
            @Model.Shifts.Count()
        </span>

    </div>

    <div class="card-body p-0">

        <table class="table table-hover mb-0">

            <thead>

                <tr>

                    <th>Date</th>
                    <th>Time</th>
                    <th>Break</th>
                    <th>Hours</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var shift in Model.Shifts
                    .Where(s => s.StartTime >= DateTime.Today)
                    .OrderBy(s => s.StartTime))
                {
                    <tr>

                        <td>
                            @shift.StartTime.ToString("ddd dd MMM")
                        </td>

                        <td>

                            @shift.StartTime.ToString("HH:mm")
                            -
                            @shift.EndTime.ToString("HH:mm")

                        </td>

                        <td>
                            @shift.BreakDuration mins
                        </td>

                        <td>
                            @shift.ShiftHours hrs
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>

<div class="card shadow-sm border-0">

    ```
    <div class="card-body">

        <div class="d-flex gap-2 flex-wrap">

            <a asp-controller="Availability"
               asp-action="Index"
               asp-route-employeeId="@Model.EmployeeID"
               class="btn btn-primary">

                Manage Availability

            </a>

            <a asp-controller="HolidayRequest"
               asp-action="Create"
               asp-route-employeeId="@Model.EmployeeID"
               class="btn btn-warning">

                Request Holiday

            </a>

            <a asp-action="Index"
               class="btn btn-outline-secondary">

                Back To Employees

            </a>

        </div>

    </div>
</div>
