@model Shift_Planner_Web.Models.Employee

@{
    ViewData["Title"] = "Employee Details";

    string status;
    string badgeClass;

    if (Model.ScheduledHours == 0)
    {
        status = "No Shifts";
        badgeClass = "bg-secondary";
    }
    else if (Model.ScheduledHours > Model.WeeklyHours)
    {
        status = "Over Contract";
        badgeClass = "bg-danger";
    }
    else if (Model.Utilisation >= 90)
    {
        status = "Fully Scheduled";
        badgeClass = "bg-success";
    }
    else
    {
        status = "Under Hours";
        badgeClass = "bg-warning text-dark";
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h1 class="fw-bold mb-1">
            @Model.Name
        </h1>

        <p class="text-muted mb-0">
            Employee Profile
        </p>

    </div>

    <span class="badge @badgeClass fs-6">
        @status
    </span>

</div>

<div class="row mb-4">

    <div class="col-md-3 mb-3">

        <div class="card h-100">

            <div class="card-body">

                <div class="text-muted small">
                    Job Role
                </div>

                <h5 class="mb-0">
                    @Model.Role.ToString().Replace("_", " ")
                </h5>

            </div>

        </div>

    </div>

    <div class="col-md-3 mb-3">

        <div class="card h-100">

            <div class="card-body">

                <div class="text-muted small">
                    Contract Hours
                </div>

                <h5 class="mb-0">
                    @Model.WeeklyHours hrs
                </h5>

            </div>

        </div>

    </div>

    <div class="col-md-3 mb-3">

        <div class="card h-100">

            <div class="card-body">

                <div class="text-muted small">
                    Scheduled Hours
                </div>

                <h5 class="mb-0">
                    @Model.ScheduledHours hrs
                </h5>

            </div>

        </div>

    </div>

    <div class="col-md-3 mb-3">

        <div class="card h-100">

            <div class="card-body">

                <div class="text-muted small">
                    Start Date
                </div>

                <h5 class="mb-0">
                    @Model.StartDate.ToString("dd MMM yyyy")
                </h5>

            </div>

        </div>

    </div>

</div>

<div class="card mb-4">

    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">

            <h5 class="mb-0">
                Utilisation
            </h5>

            <strong>
                @Model.Utilisation%
            </strong>

        </div>

        <div class="progress"
             style="height: 25px;">

            <div class="progress-bar"
                 role="progressbar"
                 style="width:@Model.Utilisation%">

                @Model.Utilisation%
            </div>

        </div>

        <div class="mt-3">

            @if (Model.RemainingHours < 0)
            {
                <span class="text-danger fw-semibold">

                    Overtime:
                    @Math.Abs(Model.RemainingHours) hrs

                </span>
            }
            else
            {
                <span class="text-success fw-semibold">

                    Remaining:
                    @Model.RemainingHours hrs

                </span>
            }

        </div>

    </div>

</div>

<div class="card mb-4">

    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">

            <h4 class="mb-0">
                Assigned Shifts
            </h4>

        </div>

        @if (Model.Shifts.Any())
        {
            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Date</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Break</th>
                            <th>Hours</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var shift in Model.Shifts)
                        {
                            <tr>

                                <td>
                                    @shift.StartTime.ToString("dd MMM yyyy")
                                </td>

                                <td>
                                    @shift.StartTime.ToString("HH:mm")
                                </td>

                                <td>
                                    @shift.EndTime.ToString("HH:mm")
                                </td>

                                <td>
                                    @shift.BreakDuration mins
                                </td>

                                <td>
                                    @shift.ShiftHours hrs
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }
        else
        {
            <div class="text-center py-4 text-muted">

                No shifts assigned.

            </div>
        }

    </div>

</div>

<div class="d-flex gap-2">

    <a asp-controller="Availability"
       asp-action="Index"
       asp-route-employeeId="@Model.EmployeeID"
       class="btn btn-primary">

        Manage Availability

    </a>

    <a asp-controller="HolidayRequest"
       asp-action="Create"
       asp-route-employeeId="@Model.EmployeeID"
       class="btn btn-warning">

        Request Holiday

    </a>

    <a asp-action="Index"
       class="btn btn-outline-secondary">

        Back to Employees

    </a>

</div>