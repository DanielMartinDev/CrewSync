@model Shift_Planner_Web.Models.Employee

<h1> Employee Details </h1>

<p>
    <strong>Name:</strong>
    @Model.Name
</p>

<p>
    <strong>Start Date:</strong>
    @Model.StartDate.ToShortDateString()
</p>

<p>
    <strong>Job Title:</strong>
    @Model.Role.ToString().Replace("_"," ")
</p>

<p>
    <strong>Weekly Hours:</strong>
    @Model.WeeklyHours
</p>

<p>
    <strong>Scheduled Hours:</strong>
    @Model.ScheduledHours
</p>

@if (Model.RemainingHours < 0)
{
    <p class="text-danger">
        Overtime:
        @Math.Abs(Model.RemainingHours) Hours
    </p>
} 
else 
{
    <p class="text-success">
        Remaining:
        @Model.RemainingHours Hours
    </p>    
}

<p>
    Utilisation:
</p>
<div class="progress">
    <div class="progress-bar"
         style="width:@Model.Utilisation%">
        @Model.Utilisation.ToString("0")%
    </div>
</div>

<p>
    Status:
    @{
        string status;
        if (Model.ScheduledHours == 0)
            status = "No Shifts";
        else if (Model.ScheduledHours > Model.WeeklyHours)
            status = "Over Contract";
        else if (Model.Utilisation >= 90)
            status = "Fully Scheduled";
        else
            status = "Under Hours";
    }
    @status
</p>


<h2> Assigned Shifts </h2>

@if (Model.Shifts.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Start</th>
                <th>End</th>
                <th>Break</th>
                <th>Working Hours</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var shift in Model.Shifts)
            {
                <tr>
                    <td>@shift.StartTime.ToShortDateString()</td>
                    <td>@shift.StartTime.ToString("HH:mm")</td>
                    <td>@shift.EndTime.ToString("HH:mm")</td>
                    <td>@shift.BreakDuration mins</td>
                    <td>@shift.ShiftHours</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No shifts assigned.</p>
}

<div>
    <a asp-controller="Availability"
       asp-action="Index"
       asp-route-employeeId="@Model.EmployeeID"
       class="btn btn-primary">

        Manage Availability

    </a>

<a asp-controller="HolidayRequest"
   asp-action="Create"
   asp-route-employeeId="@Model.EmployeeID"
   class="btn btn-warning">
    Request Holiday
</a>

</div>