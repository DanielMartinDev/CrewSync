@model List<Shift_Planner_Web.Models.Shift>

@{
    ViewData["Title"] = "Schedule";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h1 class="fw-bold mb-1">
            Schedule
        </h1>

        <p class="text-muted mb-0">
            Manage employee shifts and workforce scheduling.
        </p>

    </div>

    <a asp-action="Create"
       class="btn btn-primary">

        Create Shift

    </a>

</div>

<div class="card">

    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">

                    <tr>

                        <th>Employee</th>
                        <th>Date</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Break</th>
                        <th>Length</th>
                        <th>Paid Hours</th>
                        <th class="text-end">Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var shift in Model)
                    {
                        <tr>

                            <td>

                                <div class="fw-semibold">
                                    @shift.Employee?.Name
                                </div>

                                <small class="text-muted">
                                    Shift #@shift.ShiftID
                                </small>

                            </td>

                            <td>
                                @shift.StartTime.ToString("dd MMM yyyy")
                            </td>

                            <td>
                                @shift.StartTime.ToString("HH:mm")
                            </td>

                            <td>
                                @shift.EndTime.ToString("HH:mm")
                            </td>

                            <td>
                                @shift.BreakDuration mins
                            </td>

                            <td>
                                @shift.ShiftLength.ToString("0.0") hrs
                            </td>

                            <td>

                                <span class="badge bg-primary">

                                    @shift.ShiftHours.ToString("0.0") hrs

                                </span>

                            </td>

                            <td>

                                <div class="d-flex justify-content-end gap-2">

                                    <a asp-action="Details"
                                       asp-route-id="@shift.ShiftID"
                                       class="btn btn-outline-primary btn-sm">

                                        View

                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@shift.ShiftID"
                                       class="btn btn-outline-secondary btn-sm">

                                        Edit

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@shift.ShiftID"
                                       class="btn btn-outline-danger btn-sm">

                                        Delete

                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@if (!Model.Any())
{
    <div class="card mt-4">

        <div class="card-body text-center py-5">

            <h5 class="text-muted mb-2">
                No Shifts Scheduled
            </h5>

            <p class="text-muted mb-3">
                Create your first shift to start building the schedule.
            </p>

            <a asp-action="Create"
               class="btn btn-primary">

                Create Shift

            </a>

        </div>

    </div>
}