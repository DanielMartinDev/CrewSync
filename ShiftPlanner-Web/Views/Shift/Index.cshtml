@model List<Shift_Planner_Web.Models.Shift>

@{
    ViewData["Title"] = "Schedule";

    var weekStart = DateTime.Today.AddDays(
    -(int)DateTime.Today.DayOfWeek + 1);

    var weekEnd = weekStart.AddDays(6);

    var totalShifts = Model.Count;

    var totalHours =
        Model.Sum(s => s.ShiftHours);

    var employeeCount =
        Model.Select(s => s.EmployeeID)
             .Distinct()
             .Count();

    var todayShifts =
        Model.Where(s =>
            s.StartTime.Date ==
            DateTime.Today)
        .OrderBy(s => s.StartTime)
        .ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>

        <h1 class="fw-bold">
            Schedule
        </h1>

        <p class="text-muted mb-0">
            Workforce scheduling overview.
        </p>

    </div>

    <a asp-action="Create"
       class="btn btn-primary">

        Create Shift

    </a>
</div>

<div class="row mb-4">
    <div class="col-md-4">

        <div class="card shadow-sm">

            <div class="card-body">

                <div class="text-muted">
                    Total Shifts
                </div>

                <h2>
                    @totalShifts
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card shadow-sm">

            <div class="card-body">

                <div class="text-muted">
                    Total Hours
                </div>

                <h2>
                    @totalHours.ToString("0.0")
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card shadow-sm">

            <div class="card-body">

                <div class="text-muted">
                    Employees Scheduled
                </div>

                <h2>
                    @employeeCount
                </h2>

            </div>

        </div>

    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center">

            <h4 class="mb-0">

                Current Week

            </h4>

            <span class="text-muted">

                @weekStart.ToString("dd MMM")
                -
                @weekEnd.ToString("dd MMM yyyy")

            </span>

        </div>

    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white">

        <h5 class="mb-0">
            Today's Shifts
        </h5>

    </div>

    <div class="card-body p-0">

        @if (todayShifts.Any())
        {
            <table class="table table-hover mb-0">

                <thead>

                    <tr>

                        <th>Employee</th>
                        <th>Time</th>
                        <th>Hours</th>
                        <th></th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var shift in todayShifts)
                    {
                        <tr>

                            <td>
                                @shift.Employee?.Name
                            </td>

                            <td>

                                @shift.StartTime.ToString("HH:mm")
                                -
                                @shift.EndTime.ToString("HH:mm")

                            </td>

                            <td>
                                @shift.ShiftHours
                            </td>

                            <td>

                                <a asp-action="Edit"
                                   asp-route-id="@shift.ShiftID"
                                   class="btn btn-sm btn-outline-primary">

                                    Edit

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>
        }
        else
        {
            <div class="p-4 text-center text-muted">

                No shifts today.

            </div>
        }

    </div>
</div>