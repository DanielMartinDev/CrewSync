@model List<Shift_Planner_Web.Models.Shift>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Employee</th>
            <th>Date</th>
            <th>Start</th>
            <th>End</th>
            <th>Break</th>
            <th>Length</th>
            <th>Paid Hours</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var shift in Model)
        {
            <tr>
                <td>@shift.ShiftID</td>
                <td>@shift.Employee?.Name</td>
                <td>@shift.StartTime.ToShortDateString()</td>
                <td>@shift.StartTime.ToShortTimeString()</td>
                <td>@shift.EndTime.ToShortTimeString()</td>
                <td>@shift.BreakDuration mins</td>
                <td>@shift.ShiftLength.ToString("0.0")</td>
                <td>@shift.ShiftHours.ToString("0.0")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@shift.ShiftID"> 
                        View Shift
                    </a>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@shift.ShiftID">
                        Edit Shift
                    </a>
                </td>
                <td>
                    <a asp-action="Delete"
                       asp-route-id="@shift.ShiftID"
                       class="btn btn-danger">
                        Delete
                    </a>
                </td>
            </tr>
        }

        <a asp-action="Create" class="btn btn-primary mb-3">
            Add Shift
        </a>
    </tbody>
</table>