@using Shift_Planner_Web.Models
@model Shift_Planner_Web.Models.Shift

<h1>Create Shift</h1>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form asp-action="Create" method="post">

    <div asp-validation-summary="All"
         class="text-danger">
    </div>

    <div class="mb-3">
        <label asp-for="EmployeeID"> Employee </label>

        <select asp-for="EmployeeID"
                class="form-select"
                asp-items="ViewBag.Employees">
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="StartTime"></label>
        <input asp-for="StartTime"
               type="datetime-local"
               class="form-control" />

        <span asp-validation-for="StartTime"
              class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="EndTime"></label>
        <input asp-for="EndTime"
               type="datetime-local"
               class="form-control" />

        <span asp-validation-for="EndTime"
              class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="BreakDuration"></label>
        <input asp-for="BreakDuration"
               class="form-control" />

        <span asp-validation-for="BreakDuration"
              class="text-danger"></span>
    </div>

    <button type="submit"
            class="btn btn-success">
        Add Shift
    </button>

</form>