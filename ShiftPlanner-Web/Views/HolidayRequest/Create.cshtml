@model Shift_Planner_Web.Models.HolidayRequest

@{
    ViewData["Title"] = "Request Holiday";
}

<div class="mb-4">

    <h1 class="fw-bold mb-1">
        Request Holiday
    </h1>

    <p class="text-muted mb-0">
        Submit a holiday request for manager approval.
    </p>

</div>

<div class="row justify-content-center">

    <div class="col-lg-6">

        <div class="card">

            <div class="card-body p-4">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger mb-4">

                        @ViewBag.Error

                    </div>
                }

                <form asp-action="Create"
                      method="post">

                    <input asp-for="EmployeeID"
                           type="hidden" />

                    <div class="mb-4">

                        <label asp-for="StartDate"
                               class="form-label fw-semibold">

                            Holiday Start Date

                        </label>

                        <input asp-for="StartDate"
                               type="date"
                               class="form-control form-control-lg" />

                        <span asp-validation-for="StartDate"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="EndDate"
                               class="form-label fw-semibold">

                            Holiday End Date

                        </label>

                        <input asp-for="EndDate"
                               type="date"
                               class="form-control form-control-lg" />

                        <span asp-validation-for="EndDate"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="alert alert-info">

                        <strong>Holiday Approval Process</strong>

                        <br />

                        Your request will be submitted and remain
                        pending until approved or rejected by a manager.

                    </div>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-between">

                        @if (User.IsInRole("Employee"))
                        {
                            <a asp-controller="EmployeePortal"
                               asp-action="Index"
                               class="btn btn-outline-secondary">

                                Cancel

                            </a>
                        }
                        else
                        {
                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                Cancel

                            </a>
                        }

                        <button type="submit"
                                class="btn btn-primary">

                            Submit Request

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}