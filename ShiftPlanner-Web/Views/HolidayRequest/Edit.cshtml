@model Shift_Planner_Web.Models.HolidayRequest

@{
    ViewData["Title"] = "Edit Holiday Request";
}

<div class="mb-4">

    <h1 class="fw-bold mb-1">
        Edit Holiday Request
    </h1>

    <p class="text-muted mb-0">
        Update holiday dates and approval status.
    </p>

</div>

<div class="row justify-content-center">

    <div class="col-lg-6">

        <div class="card">

            <div class="card-body p-4">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All"
                         class="alert alert-danger mb-4">
                    </div>
                }

                <form asp-action="Edit"
                      method="post">

                    <input asp-for="HolidayRequestID"
                           type="hidden" />

                    <input asp-for="EmployeeID"
                           type="hidden" />

                    <div class="mb-4">

                        <label asp-for="StartDate"
                               class="form-label fw-semibold">

                            Holiday Start Date

                        </label>

                        <input asp-for="StartDate"
                               type="date"
                               class="form-control form-control-lg" />

                        <span asp-validation-for="StartDate"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="EndDate"
                               class="form-label fw-semibold">

                            Holiday End Date

                        </label>

                        <input asp-for="EndDate"
                               type="date"
                               class="form-control form-control-lg" />

                        <span asp-validation-for="EndDate"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Status"
                               class="form-label fw-semibold">

                            Request Status

                        </label>

                        <select asp-for="Status"
                                class="form-select form-select-lg">

                            <option value="0">
                                Pending
                            </option>

                            <option value="1">
                                Approved
                            </option>

                            <option value="2">
                                Rejected
                            </option>

                        </select>

                        <span asp-validation-for="Status"
                              class="text-danger">
                        </span>

                        <div class="mb-3">

                            <label asp-for="ManagerNotes"
                                   class="form-label">

                                Manager Notes

                            </label>        

                            <textarea asp-for="ManagerNotes"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Optional notes for the employee...">
                            </textarea>

                        </div>

                    </div>

                    <div class="alert alert-info">

                        <strong>Status Guide</strong>

                        <ul class="mb-0 mt-2">

                            <li>
                                Pending - Awaiting review
                            </li>

                            <li>
                                Approved - Employee may take leave
                            </li>

                            <li>
                                Rejected - Leave request denied
                            </li>

                        </ul>

                    </div>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-between">

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">

                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-primary">

                            Save Changes

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}