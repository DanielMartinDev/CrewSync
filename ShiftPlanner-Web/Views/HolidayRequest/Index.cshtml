@model List<Shift_Planner_Web.Models.HolidayRequest>

<h2>Holiday Requests</h2>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Employee</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Actions</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var request in Model)
        {
            <tr>

                <td>@request.Employee?.Name</td>

                <td>
                    @request.StartDate.ToString("dd/MM/yyyy")
                </td>

                <td>
                    @request.EndDate.ToString("dd/MM/yyyy")
                </td>

                <td>
                    @request.Status
                </td>

                <td>
                    @if (request.Status == Shift_Planner_Web.Models.HolidayRequestStatus.Pending)
                    {
                        <form asp-action="Approve"
                              asp-route-id="@request.HolidayRequestID"
                              method="post"
                              class="d-inline">

                            <button type="submit"
                                    class="btn btn-success btn-sm">
                                Approve
                            </button>

                        </form>

                        <form asp-action="Reject"
                              asp-route-id="@request.HolidayRequestID"
                              method="post"
                              class="d-inline">

                            <button type="submit"
                                    class="btn btn-danger btn-sm">
                                Reject
                            </button>

                        </form>
                    }

                    <a asp-action="Delete"
                       asp-route-id="@request.HolidayRequestID"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>

            </tr>
        }

    </tbody>

</table>