@model List<Shift_Planner_Web.Models.HolidayRequest>

@{
    ViewData["Title"] = "Holiday Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h1 class="fw-bold mb-1">
            Holiday Requests
        </h1>

        <p class="text-muted mb-0">
            Review and manage employee holiday requests.
        </p>

    </div>

    <div class="badge bg-warning text-dark fs-6">

        @Model.Count(r =>
            r.Status == Shift_Planner_Web.Models.HolidayRequestStatus.Pending)

        Pending

    </div>

</div>

<div class="card">

    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">

                    <tr>

                        <th>Employee</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var request in Model)
                    {
                        string badgeClass = request.Status switch
                        {
                            Shift_Planner_Web.Models.HolidayRequestStatus.Pending
                                => "bg-warning text-dark",

                            Shift_Planner_Web.Models.HolidayRequestStatus.Approved
                                => "bg-success",

                            Shift_Planner_Web.Models.HolidayRequestStatus.Rejected
                                => "bg-danger",

                            _ => "bg-secondary"
                        };

                        <tr>

                            <td>

                                <div class="fw-semibold">
                                    @request.Employee?.Name
                                </div>

                            </td>

                            <td>
                                @request.StartDate.ToString("dd MMM yyyy")
                            </td>

                            <td>
                                @request.EndDate.ToString("dd MMM yyyy")
                            </td>

                            <td>

                                <span class="badge @badgeClass">

                                    @request.Status

                                </span>

                            </td>

                            <td>

                                <div class="d-flex justify-content-end gap-2">

                                    @if (request.Status ==
                                         Shift_Planner_Web.Models.HolidayRequestStatus.Pending)
                                    {
                                        <form asp-action="Approve"
                                              asp-route-id="@request.HolidayRequestID"
                                              method="post">

                                            <button type="submit"
                                                    class="btn btn-success btn-sm">

                                                Approve

                                            </button>

                                        </form>

                                        <form asp-action="Reject"
                                              asp-route-id="@request.HolidayRequestID"
                                              method="post">

                                            <button type="submit"
                                                    class="btn btn-outline-danger btn-sm">

                                                Reject

                                            </button>

                                        </form>
                                    }

                                    <a asp-action="Edit"
                                       asp-route-id="@request.HolidayRequestID"
                                       class="btn btn-outline-secondary btn-sm">

                                        Edit

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@request.HolidayRequestID"
                                       class="btn btn-outline-danger btn-sm">

                                        Delete

                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@if (!Model.Any())
{
    <div class="card mt-4">

        <div class="card-body text-center py-5">

            <h5 class="text-muted mb-2">
                No Holiday Requests
            </h5>

            <p class="text-muted mb-0">
                Holiday requests will appear here when submitted.
            </p>

        </div>

    </div>
}