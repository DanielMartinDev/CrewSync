@model Shift_Planner_Web.Models.HolidayRequest

@{
    ViewData["Title"] = "Delete Holiday Request";
}

<div class="row justify-content-center">

    <div class="col-lg-6">

        <div class="card border-danger">

            <div class="card-body p-4">

                <div class="text-center mb-4">

                    <h1 class="text-danger fw-bold mb-2">
                        Delete Holiday Request
                    </h1>

                    <p class="text-muted mb-0">
                        This action cannot be undone.
                    </p>

                </div>

                <div class="alert alert-danger">

                    <strong>
                        Warning:
                    </strong>

                    This holiday request will be permanently removed
                    from CrewSync.

                </div>

                <div class="card bg-light border-0 mb-4">

                    <div class="card-body">

                        <div class="row g-3">

                            <div class="col-md-6">

                                <div class="text-muted small">
                                    Employee
                                </div>

                                <div class="fw-semibold">
                                    @Model.Employee?.Name
                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="text-muted small">
                                    Status
                                </div>

                                <div>
                                    @Model.Status
                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="text-muted small">
                                    Start Date
                                </div>

                                <div>
                                    @Model.StartDate.ToString("dd MMM yyyy")
                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="text-muted small">
                                    End Date
                                </div>

                                <div>
                                    @Model.EndDate.ToString("dd MMM yyyy")
                                </div>

                            </div>

                        </div>

                    </div>

                </div>

                <form asp-action="Delete"
                      method="post">

                    <input asp-for="HolidayRequestID"
                           type="hidden" />

                    <div class="d-flex justify-content-between">

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">

                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-danger">

                            Delete Request

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>