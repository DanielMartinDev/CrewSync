@model ShiftPlanner_Web.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center">

    <div class="col-lg-6">

        <div class="text-center mb-4">

            <h1 class="fw-bold">
                Welcome to CrewSync
            </h1>

            <p class="text-muted">
                Before accessing your account, you'll need to create a new password.
            </p>

        </div>

        <div class="card">

            <div class="card-body p-4">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All"
                         class="alert alert-danger mb-4">
                    </div>
                }

                <form asp-action="ChangePassword"
                      method="post">

                    <div class="mb-4">

                        <label asp-for="CurrentPassword"
                               class="form-label fw-semibold">

                            Temporary Password

                        </label>

                        <input asp-for="CurrentPassword"
                               type="password"
                               class="form-control form-control-lg" />

                        <span asp-validation-for="CurrentPassword"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="NewPassword"
                               class="form-label fw-semibold">

                            New Password

                        </label>

                        <input asp-for="NewPassword"
                               type="password"
                               class="form-control form-control-lg" />

                        <span asp-validation-for="NewPassword"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="ConfirmPassword"
                               class="form-label fw-semibold">

                            Confirm New Password

                        </label>

                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control form-control-lg" />

                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="alert alert-info">

                        <strong>Password Requirements</strong>

                        <ul class="mb-0 mt-2">

                            <li>At least 8 characters</li>
                            <li>Include an uppercase letter</li>
                            <li>Include a number</li>
                            <li>Include a special character</li>

                        </ul>

                    </div>

                    <div class="d-grid">

                        <button type="submit"
                                class="btn btn-primary btn-lg">

                            Update Password

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}