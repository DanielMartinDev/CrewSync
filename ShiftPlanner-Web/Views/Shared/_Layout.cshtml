<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - CrewSync
    </title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/ShiftPlanner_Web.styles.css"
          asp-append-version="true" />

</head>

<body class="bg-light">

    <div class="d-flex min-vh-100">

        <!-- Sidebar -->

        <aside class="bg-white border-end shadow-sm"
               style="width:260px;">

            <div class="p-4 border-bottom">

                <h3 class="fw-bold text-primary mb-0">
                    CrewSync
                </h3>

                <small class="text-muted">
                    Workforce Management
                </small>

            </div>

            <nav class="p-3">

                <ul class="nav flex-column">

                    @if (User.Identity?.IsAuthenticated == true &&
                         !User.IsInRole("Employee"))
                    {
                        <li class="nav-item mb-2">

                            <a class="nav-link text-dark"
                               asp-controller="Home"
                               asp-action="Dashboard">

                                📊 Dashboard

                            </a>

                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item mb-2">

                            <a class="nav-link text-dark"
                               asp-controller="Employee"
                               asp-action="Index">

                                👥 Employees

                            </a>

                        </li>
                    }

                    @if (User.IsInRole("Admin") ||
                         User.IsInRole("Manager"))
                    {
                        <li class="nav-item mb-2">

                            <a class="nav-link text-dark"
                               asp-controller="Shift"
                               asp-action="Index">

                                📅 Schedule

                            </a>

                        </li>

                        <li class="nav-item mb-2">

                            <a class="nav-link text-dark"
                               asp-controller="HolidayRequest"
                               asp-action="Index">

                                🏖 Holiday Requests

                            </a>

                        </li>
                    }

                    @if (User.IsInRole("Employee"))
                    {
                        <li class="nav-item mb-2">

                            <a class="nav-link text-dark"
                               asp-controller="EmployeePortal"
                               asp-action="Index">

                                👤 My Portal

                            </a>

                        </li>
                    }

                </ul>

            </nav>

        </aside>

        <!-- Main Content -->

        <div class="flex-grow-1">

            <!-- Top Bar -->

            <header class="bg-white border-bottom shadow-sm">

                <div class="container-fluid">

                    <div class="d-flex justify-content-between align-items-center py-3">

                        <div>

                            <h5 class="mb-0 fw-semibold">
                                @ViewData["Title"]
                            </h5>

                        </div>

                        <div class="d-flex align-items-center gap-2">

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <span class="text-muted">

                                    @User.Identity.Name

                                </span>

                                @if (User.IsInRole("Admin"))
                                {
                                    <span class="badge bg-danger">
                                        Store Manager
                                    </span>
                                }
                                else if (User.IsInRole("Manager"))
                                {
                                    <span class="badge bg-warning text-dark">
                                        Deputy Store Manager
                                    </span>
                                }
                                else if (User.IsInRole("Employee"))
                                {
                                    <span class="badge bg-primary">
                                        Employee
                                    </span>
                                }

                                <form asp-controller="Account"
                                      asp-action="Logout"
                                      method="post">

                                    <button type="submit"
                                            class="btn btn-outline-danger btn-sm">

                                        Logout

                                    </button>

                                </form>
                            }
                            else
                            {
                                <a asp-controller="Account"
                                   asp-action="Login"
                                   class="btn btn-primary btn-sm">

                                    Login

                                </a>
                            }

                        </div>

                    </div>

                </div>

            </header>

            <!-- Page Content -->

            <main class="p-4">

                @RenderBody()

            </main>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>