@model List<ShiftPlanner_Web.Models.Availability>

<h2>Manage Availability</h2>

<form asp-action="Index" method="post">

    <table class="table table-bordered align-middle">

        <thead>
            <tr>
                <th>Day</th>
                <th>Available</th>
                <th>From</th>
                <th>To</th>
            </tr>
        </thead>

        <tbody>

            @for (int i = 0; i < Model.Count; i++)
            {
                <tr>

                    <td>
                        @Model[i].DayOfWeek

                        <input type="hidden"
                               asp-for="@Model[i].AvailabilityID" />

                        <input type="hidden"
                               asp-for="@Model[i].EmployeeID" />

                        <input type="hidden"
                               asp-for="@Model[i].DayOfWeek" />
                    </td>

                    <td>
                        <input asp-for="@Model[i].IsAvailable"
                               class="form-check-input" />
                    </td>

                    <td>
                        <input asp-for="@Model[i].AvailableFrom"
                               type="time"
                               class="form-control" />
                    </td>

                    <td>
                        <input asp-for="@Model[i].AvailableTo"
                               type="time"
                               class="form-control" />
                    </td>

                </tr>
            }

        </tbody>

    </table>

    <button type="submit"
            class="btn btn-success">
        Save Changes
    </button>

</form>