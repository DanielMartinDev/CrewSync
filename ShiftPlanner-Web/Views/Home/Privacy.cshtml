@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="mb-4">

    <h1 class="fw-bold mb-1">
        Privacy Policy
    </h1>

    <p class="text-muted mb-0">
        How CrewSync collects, uses and protects information.
    </p>

</div>

<div class="card">

    <div class="card-body p-4">

        <h4>Introduction</h4>

        <p>
            CrewSync is a workforce management platform designed to help
            businesses manage employees, schedules, availability and
            holiday requests.
        </p>

        <p>
            We are committed to protecting the privacy and security of
            employee and business information.
        </p>

        <hr />

        <h4>Information We Collect</h4>

        <p>
            CrewSync may collect and store:
        </p>

        <ul>

            <li>Employee names</li>
            <li>Email addresses</li>
            <li>Work schedules</li>
            <li>Availability information</li>
            <li>Holiday requests</li>
            <li>Login and account information</li>

        </ul>

        <hr />

        <h4>How Information Is Used</h4>

        <p>
            Information is used solely for workforce management purposes,
            including:
        </p>

        <ul>

            <li>Scheduling employees</li>
            <li>Managing holiday requests</li>
            <li>Monitoring contracted hours</li>
            <li>Providing employee portal access</li>
            <li>Supporting business operations</li>

        </ul>

        <hr />

        <h4>Data Security</h4>

        <p>
            CrewSync takes reasonable measures to protect data against
            unauthorised access, disclosure or loss. Passwords are stored
            using secure industry-standard hashing mechanisms provided by
            ASP.NET Identity.
        </p>

        <hr />

        <h4>Data Sharing</h4>

        <p>
            CrewSync does not sell personal information. Data is only
            accessible to authorised users within the organisation using
            the platform.
        </p>

        <hr />

        <h4>Employee Rights</h4>

        <p>
            Employees may request correction of inaccurate information
            held within the platform by contacting their employer.
        </p>

        <hr />

        <h4>Contact</h4>

        <p>
            For questions regarding privacy or data protection, please
            contact the system administrator.
        </p>

        <hr />

        <p class="text-muted mb-0">

            Last Updated: June 2026

        </p>

    </div>

</div>