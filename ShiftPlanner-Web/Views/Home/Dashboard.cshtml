@using Shift_Planner_Web.Models
@model ShiftPlanner_Web.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <h1 class="fw-bold mb-1">
        Dashboard
    </h1>

    <p class="text-muted mb-0">
        Monitor staffing, schedules and holiday requests.
    </p>
</div>

@if (Model.OverHoursEmployees.Any() || Model.NoShiftEmployees.Any())
{
    <div class="card mb-4">
        <div class="card-body">

            <h5 class="fw-bold mb-3">
                Staffing Alerts
            </h5>

            <ul class="mb-0">

                @foreach (var employee in Model.OverHoursEmployees)
                {
                    <li>
                        @employee.Name exceeds contracted hours
                    </li>
                }

                @foreach (var employee in Model.NoShiftEmployees)
                {
                    <li>
                        @employee.Name has no shifts assigned this week
                    </li>
                }

            </ul>

        </div>

    </div>
}

<div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">

        <div class="card h-100">

            <div class="card-body">

                <div class="text-muted small mb-2">
                    Total Employees
                </div>

                <h2 class="fw-bold mb-0">
                    @Model.EmployeeCount
                </h2>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-md-6 mb-3">

        <div class="card h-100">

            <div class="card-body">

                <div class="text-muted small mb-2">
                    Total Shifts
                </div>

                <h2 class="fw-bold mb-0">
                    @Model.ShiftCount
                </h2>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-md-6 mb-3">

        <div class="card h-100">

            <div class="card-body">

                <div class="text-muted small mb-2">
                    Scheduled Hours
                </div>

                <h2 class="fw-bold mb-0">
                    @Model.TotalHours
                </h2>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-md-6 mb-3">

        <a asp-controller="HolidayRequest"
           asp-action="Index"
           class="text-decoration-none">

            <div class="card h-100 bg-warning-subtle">

                <div class="card-body">

                    <div class="text-muted small mb-2">
                        Pending Holidays
                    </div>

                    <h2 class="fw-bold mb-0 text-dark">
                        @Model.PendingHolidayRequests.Count
                    </h2>

                </div>

            </div>

        </a>

    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>

        <h3 class="fw-bold mb-0">
            Weekly Schedule
        </h3>

        <small class="text-muted">
            Week beginning
            @Model.WeekStart.ToString("dd MMM yyyy")
        </small>

    </div>

    <div class="d-flex gap-2">

        <a asp-action="Dashboard"
           asp-route-weekStart="@Model.WeekStart.AddDays(-7).ToString("yyyy-MM-dd")"
           class="btn btn-outline-secondary">

            Previous Week

        </a>

        <a asp-action="Dashboard"
           asp-route-weekStart="@Model.WeekStart.AddDays(7).ToString("yyyy-MM-dd")"
           class="btn btn-primary">

            Next Week

        </a>

    </div>
</div>

<div class="card">
    <div class="table-responsive">

        <table class="table table-hover align-middle mb-0">

            <thead class="table-light">

                <tr>

                    <th>Employee</th>

                    <th>Mon</th>
                    <th>Tue</th>
                    <th>Wed</th>
                    <th>Thu</th>
                    <th>Fri</th>
                    <th>Sat</th>
                    <th>Sun</th>

                    <th>Total</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var employee in Model.Employees)
                {
                    <tr>

                        <td class="fw-semibold">
                            @employee.Name
                        </td>

                        @for (int i = 0; i < 7; i++)
                        {
                            var day = Model.WeekStart.AddDays(i);

                            var shift = Model.UpcomingShifts
                                .FirstOrDefault(
                                    s =>
                                    s.EmployeeID == employee.EmployeeID &&
                                    s.StartTime.Date == day.Date);

                            var holiday =
                                Model.HolidayRequests
                                .FirstOrDefault(h =>
                                    h.EmployeeID == employee.EmployeeID &&
                                    h.Status == HolidayRequestStatus.Approved &&
                                    day.Date >= h.StartDate.Date &&
                                    day.Date <= h.EndDate.Date);

                            <td class="text-center">

                                @if (shift != null)
                                {
                                    <a asp-controller="Shift"
                                       asp-action="Edit"
                                       asp-route-id="@shift.ShiftID"
                                       class="text-decoration-none">

                                        <div class="bg-primary bg-opacity-10 rounded p-2">

                                            <div class="fw-semibold text-dark">

                                                @shift.StartTime.ToString("HH:mm")
                                                -
                                                @shift.EndTime.ToString("HH:mm")

                                            </div>

                                            <small class="text-muted">

                                                @shift.ShiftHours.ToString("0.0") hrs

                                            </small>

                                        </div>

                                    </a>
                                }
                                else if (holiday != null)
                                {
                                    <span class="badge bg-warning text-dark px-3 py-2">
                                        Holiday
                                    </span>
                                }
                                else
                                {
                                    <a asp-controller="Shift"
                                       asp-action="Create"
                                       asp-route-employeeId="@employee.EmployeeID"
                                       asp-route-date="@day.ToString("yyyy-MM-dd")"
                                       class="text-decoration-none">

                                        <span class="text-muted">
                                            Off
                                        </span>

                                    </a>
                                }

                            </td>
                        }

                        <td>

                            @{
                                var weeklyHours = Model.UpcomingShifts
                                    .Where(s => s.EmployeeID == employee.EmployeeID)
                                    .Sum(s => s.ShiftHours);

                                var overHours =
                                    weeklyHours > employee.WeeklyHours;
                            }

                            @if (overHours)
                            {
                                <span class="fw-bold text-danger">
                                    @weeklyHours.ToString("0.0") hrs
                                </span>
                            }
                            else
                            {
                                <span class="fw-semibold">
                                    @weeklyHours.ToString("0.0") hrs
                                </span>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>