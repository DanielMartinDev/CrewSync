@model ShiftPlanner_Web.ViewModels.DashboardViewModel

@if (Model.OverHoursEmployees.Any())
{
    <div class="alert alert-danger">

        <h5>Warnings</h5>

        <ul>
            @foreach (var employee in Model.OverHoursEmployees)
            {
                <li>
                    @employee.Name exceeds
                    contracted hours
                </li>
            }
        </ul>

    </div>
}

@if (Model.NoShiftEmployees.Any())
{
    <div class="alert alert-warning">

        <h5>Warnings</h5>

        <ul>
            @foreach (var employee in Model.NoShiftEmployees)
            {
                <li>
                    @employee.Name Has
                    no shifts assigned
                </li>
            }
        </ul>

    </div>
}

<div class="row">

    <div class="col-md-6">
        <div class="card">
            <div class="card-body">

                <h5>Total Employees</h5>

                <h2>@Model.EmployeeCount</h2>

            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-body">

                <h5>Total Shifts</h5>

                <h2>@Model.ShiftCount</h2>

            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-body">

                <h5>Total Hours Used</h5>

                <h2>@Model.TotalHours</h2>

            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-body">

                <h5>Average Contract</h5>
                <h2>@Model.AverageContractHours Hours</h2>
            </div>
        </div>
    </div>

    <h2>Weekly Schedule</h2>

    <div class="d-flex justify-content-between mb-3">

        <a asp-action="Dashboard"
           asp-route-weekStart="@Model.WeekStart.AddDays(-7).ToString("yyyy-MM-dd")"
           class="btn btn-secondary">
            Previous Week
        </a>

        <h4>
            Week Beginning
            @Model.WeekStart.ToString("dd/MM/yyyy")
        </h4>

        <a asp-action="Dashboard"
           asp-route-weekStart="@Model.WeekStart.AddDays(7).ToString("yyyy-MM-dd")"
           class="btn btn-secondary">
            Next Week
        </a>

    </div>

<div>
    <table class="table table-bordered">

        <thead>
            <tr>
                <th>Employee</th>

                <th>Mon</th>
                <th>Tue</th>
                <th>Wed</th>
                <th>Thu</th>
                <th>Fri</th>
                <th>Sat</th>
                <th>Sun</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var employee in Model.Employees)
            {
                <tr>

                    <td>
                        @employee.Name
                    </td>

                    @for (int i = 0; i < 7; i++)
                    {
                        var day = Model.WeekStart.AddDays(i);

                            var shift = Model.UpcomingShifts
                                .FirstOrDefault(
                                    s =>
                                    s.EmployeeID == employee.EmployeeID &&
                                    s.StartTime.Date == day.Date);
                            <td class="text-center align-middle">

                                @if (shift != null)
                                {
                                    <strong>
                                        @shift.StartTime.ToString("HH:mm")
                                        -
                                        @shift.EndTime.ToString("HH:mm")
                                    </strong>

                                    <br />

                                    <small>
                                        @shift.ShiftHours hrs
                                    </small>
                                }
                            else
                            {
                                <span>OFF</span>
                            }
                            </td>
                    }

                </tr>
            }

        </tbody>

    </table>
</div>