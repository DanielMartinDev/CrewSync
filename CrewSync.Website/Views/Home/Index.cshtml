
<section class="py-5 text-center">
    <div class="container">

        <span class="badge bg-primary mb-3">
            Early Access Coming Soon
        </span>

        <h1 class="display-2 fw-bold mb-4">
            CrewSync
        </h1>

        <p class="lead fs-4">

            Stop managing staff schedules in spreadsheets.

        </p>

        <p class="text-muted fs-5 mb-4">

            Schedule employees, approve holidays and give staff
            self-service access from one modern platform.

        </p>

        <div class="mt-4">

            <a href="#waitlist"
               class="btn btn-primary btn-lg me-2">

                Join Waitlist

            </a>

            <a href="#features"
               class="btn btn-outline-secondary btn-lg">

                Learn More

            </a>

        </div>

    </div>
</section>

<section id="features" class="py-5 bg-light">
    <div class="container">

        <div class="text-center mb-5">

            <h2 class="fw-bold">
                Everything You Need To Manage Your Workforce
            </h2>

            <p class="text-muted">
                Designed for retail stores, hospitality teams and growing businesses.
            </p>

        </div>

        <div class="row g-4">

            <div class="col-md-3">

                <div class="card h-100 shadow-sm">

                    <div class="card-body">

                        <h4>📅 Scheduling</h4>

                        <p>
                            Create and manage employee schedules in minutes.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card h-100 shadow-sm">

                    <div class="card-body">

                        <h4>🏖️ Holidays</h4>

                        <p>
                            Approve, reject and track holiday requests.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card h-100 shadow-sm">

                    <div class="card-body">

                        <h4>👤 Employee Portal</h4>

                        <p>
                            View shifts, request holidays and manage availability.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card h-100 shadow-sm">

                    <div class="card-body">

                        <h4>📊 Insights</h4>

                        <p>
                            Track utilisation, contracted hours and staffing issues.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>
</section>

