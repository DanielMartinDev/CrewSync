            <div class="card-body text-center py-4">

                <h3 class="fw-bold">
                    Manager Dashboard
                </h3>

                <p class="text-muted mb-0">
                    Monitor staffing levels, weekly schedules, utilisation and holiday requests from a single dashboard.
                </p>

            </div>

        </div>

        <!-- Supporting Screenshots -->

        <div class="row g-4">

            <div class="col-lg-4">

                <div class="card shadow-sm border-0 h-100 screenshot-card">

                    <img src="/images/Employees.png"
                         class="img-fluid rounded-top"
                         alt="Employee Management" />

                    <div class="card-body">

                        <h5 class="fw-bold">
                            Employee Management
                        </h5>

                        <p class="text-muted mb-0">
                            Manage contracts, track utilisation and monitor workforce performance.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="card shadow-sm border-0 h-100 screenshot-card">

                    <img src="/images/EmployeePortal.png"
                         class="img-fluid rounded-top"
                         alt="Employee Portal" />

                    <div class="card-body">

                        <h5 class="fw-bold">
                            Employee Portal
                        </h5>

                        <p class="text-muted mb-0">
                            View shifts, request holidays and manage availability from anywhere.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="card shadow-sm border-0 h-100 screenshot-card">

                    <img src="/images/HolidayRequests.png"
                         class="img-fluid rounded-top"
                         alt="Holiday Management" />

                    <div class="card-body">

                        <h5 class="fw-bold">
                            Holiday Management
                        </h5>

                        <p class="text-muted mb-0">
                            Review requests, approve leave and maintain a clear holiday record.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>
</section>

