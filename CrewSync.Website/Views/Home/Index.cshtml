<section id="waitlist" class="py-5 bg-light">
    <div class="container text-center">

        <h2 class="fw-bold">

            Join The CrewSync Waitlist

        </h2>

        <p class="text-muted">

            Be among the first businesses to gain access and help shape the future of CrewSync.

        </p>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success">

                @TempData["Message"]

            </div>
        }

        <form asp-controller="Waitlist"
              asp-action="Join"
              method="post">

            <div class="mb-3">
                <input name="Name"
                       class="form-control"
                       placeholder="Your Name" />
            </div>

            <div class="mb-3">
                <input name="Email"
                       type="email"
                       class="form-control"
                       placeholder="Work Email" />
            </div>

            <div class="mb-3">
                <input name="CompanyName"
                       class="form-control"
                       placeholder="Company Name" />
            </div>

            <div class="mb-3">

                <select name="Industry"
                        class="form-select">

                    <option value="">
                        Select Industry
                    </option>

                    <option>
                        Retail
                    </option>

                    <option>
                        Hospitality
                    </option>

                    <option>
                        Healthcare
                    </option>

                    <option>
                        Office / Professional Services
                    </option>

                    <option>
                        Other
                    </option>

                </select>

            </div>

            <div class="mb-3">

                <select name="EmployeeCount"
                        class="form-select">

                    <option value="0">
                        Team Size
                    </option>

                    <option value="10">
                        1-10 Employees
                    </option>

                    <option value="50">
                        11-50 Employees
                    </option>

                    <option value="100">
                        51-100 Employees
                    </option>

                    <option value="500">
                        100+ Employees
                    </option>

                </select>

            </div>

            <div class="mb-3">

                <textarea name="Notes"
                          class="form-control"
                          rows="3"
                          placeholder="What scheduling problems are you looking to solve?"></textarea>

            </div>

            <div class="form-check mb-3">

                <input name="PrivacyConsent"
                       type="checkbox"
                       value="true"
                       required />

                <label class="form-check-label"
                       for="privacyConsent">

                    I agree to receive updates about CrewSync and
                    understand my information will be stored in accordance
                    with the

                    <a asp-controller="Home"
                       asp-action="Privacy">

                        Privacy Policy

                    </a>.

                </label>

            </div>

            <button type="submit"
                    class="btn btn-primary">
                Join Waitlist
            </button>

        </form>

        <p class="small text-muted mt-3">
            No spam. Early access updates only.
        </p>

    </div>
</section>