        "format": "int32"
      },
      "Employee": {
        "required": [
          "employeeID",
          "name",
          "role"
        ],
        "type": "object",
        "properties": {
          "employeeID": {
            "type": "integer",
            "format": "int32"
          },
          "userId": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "user": {
            "$ref": "#/components/schemas/ApplicationUser"
          },
          "name": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "weeklyHours": {
            "maximum": 60,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "role": {
            "$ref": "#/components/schemas/Role"
          },
          "shifts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Shift"
            },
            "nullable": true
          },
          "scheduledHours": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "remainingHours": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "utilisation": {
            "type": "number",
            "format": "double",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "HolidayRequest": {
        "type": "object",
