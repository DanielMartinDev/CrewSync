          "holidayRequestID": {
            "type": "integer",
            "format": "int32"
          },
          "employeeID": {
            "type": "integer",
            "format": "int32"
          },
          "employee": {
            "$ref": "#/components/schemas/Employee"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "$ref": "#/components/schemas/HolidayRequestStatus"
          }
        },
        "additionalProperties": false
      },
